# ===== KIS API =====
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT=01
# Production: https://openapi.koreainvestment.com:9443
# Paper: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_WS_URL=ws://ops.koreainvestment.com:21000

# ===== Trading =====
TRADING_MODE=paper
TRADING_EVALUATION_INTERVAL_SEC=300
TRADING_INITIAL_BALANCE_USD=10000
TRADING_MIN_CONFIDENCE=0.50
TRADING_MAX_POSITIONS=10

# ===== ETF Engine =====
ETF_ENABLED=true
ETF_MAX_PORTFOLIO_PCT=0.30
ETF_MAX_HOLD_DAYS=10

# ===== Risk =====
RISK_MAX_SINGLE_STOCK_PCT=0.20
RISK_MAX_INVESTED_PCT=0.80
RISK_MAX_DRAWDOWN_PCT=0.15
RISK_DAILY_LOSS_LIMIT_PCT=0.03
RISK_VIX_THRESHOLD=35

# ===== Database (shared with coin's PostgreSQL container) =====
DB_URL=postgresql+asyncpg://usstock:usstock@localhost:5432/us_stock_trading

# ===== Redis (db 1 — coin uses db 0) =====
REDIS_URL=redis://localhost:6379/1

# ===== Notifications (Discord primary) =====
NOTIFY_ENABLED=false
NOTIFY_PROVIDER=discord
NOTIFY_DISCORD_WEBHOOK_URL=
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_SLACK_WEBHOOK_URL=

# ===== LLM (AI Agent) =====
LLM_ENABLED=false
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_FALLBACK_MODEL=claude-sonnet-4-6
LLM_GEMINI_API_KEY=
LLM_GEMINI_FALLBACK_MODEL=gemini-3-flash-preview
LLM_MAX_TOKENS=4096

# ===== External Data =====
EXTERNAL_FRED_API_KEY=
EXTERNAL_FINNHUB_API_KEY=

# ===== API Auth (empty = auth disabled) =====
AUTH_API_TOKEN=

# ===== Logging =====
APP_LOG_LEVEL=INFO
